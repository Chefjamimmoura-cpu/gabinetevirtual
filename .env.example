# ============================================================
# Gabinete Virtual — Variáveis de Ambiente
# Copiar para .env (VPS) e .env.local (dev local)
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://drrzyitmlgeozxwubsyl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (backend only — nunca expor no cliente)
GEMINI_API_KEY=

# Evolution API — WhatsApp (CIa Assistente Virtual)
# Instale/hospede a Evolution API: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=gabinete-carol
# Secret para validar webhooks da Evolution API (openssl rand -hex 32)
# Configurar o mesmo valor no dashboard da Evolution > Settings > Webhook Auth Token
EVOLUTION_WEBHOOK_SECRET=

# Sync SAPL (V3-F1 — Mirroring Passivo)
# Secret para autenticar o cron que chama POST /api/admin/sync-sapl
# Gere com: openssl rand -hex 32
SYNC_SECRET=

# ID do gabinete ativo no Supabase (Carol Dantas — padrão)
# Alterar em deploy multi-tenant futuro
GABINETE_ID=f25299db-1c33-45b9-830f-82f6d2d666ef

# Auto-Protocolo SAPL (V3-F7)
# Token DRF do usuário da vereadora no SAPL da CMBV.
# Obter com o TI da câmara: python manage.py drf_create_token <username>
# Ou via: POST /api/sapl/auth (apenas em dev local)
SAPL_API_TOKEN=
# ID da Carol Dantas como Autor no SAPL (não muda)
SAPL_AUTOR_ID=127
# ID do usuário de envio (usuario_envio) — pedir ao TI da câmara
SAPL_USUARIO_ENVIO_ID=

# Importação Fala Cidadão (V3-F8 — USO ÚNICO para migrar dados históricos)
# Após rodar POST /api/indicacoes/fala-cidadao, estas vars podem ser removidas
FALA_CIDADAO_API_URL=
FALA_CIDADAO_APP_KEY=
FALA_CIDADAO_LOGIN=
FALA_CIDADAO_PASSWORD=

# YouTube Data API v3 (listagem de vídeos do canal @camaraboavista)
# Criar em: console.cloud.google.com > APIs e serviços > Credenciais
# Restringir apenas à YouTube Data API v3
YOUTUBE_API_KEY=

# Groq — transcrição de sessões (Whisper)
GROQ_API_KEY=

# Stripe — billing (validação de webhook)
# Obter em: dashboard.stripe.com > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=

# URL base da aplicação (para chamadas internas do webhook ALIA)
# Em produção: https://gabinete.wonetechnology.cloud
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# ALIA CORE ENGINE (2026-04)
# ============================================================

# Secret para autenticar os crons da ALIA (memory-decay, proactive, sentinel, legal-sync)
# Gere com: openssl rand -hex 32
# Usado por TODOS os endpoints em /api/cron/alia-*
CRON_SECRET=

# Anthropic / Claude — usado pelos agentes complexos (parecer, relator, pls, crossmodule)
# Se não configurar, ALIA faz fallback para Gemini Pro automaticamente
# Criar em: https://platform.claude.com/settings/workspaces/default/keys
ANTHROPIC_API_KEY=

# (LEGACY) Números WhatsApp para alertas proativos — SUBSTITUÍDO pela tabela
# gabinete_whatsapp_recipients (configurável via /configuracoes/whatsapp).
# Mantido apenas como fallback se a tabela estiver vazia.
# Formato: números E.164 separados por vírgula, sem +
# Exemplo: 5595991234567,5595999998888
ALIA_NOTIFY_NUMBERS=
